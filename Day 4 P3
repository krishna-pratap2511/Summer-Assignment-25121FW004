#include<stdio.h>
int main()
{
    int n,a=0,b=1,c,i;
    printf("Enter the number till which you want to print the Fibonacci series");
    scanf("%d",&n);
    printf("The FIbonacci Series is:%d %d",a,b);
    for(i=3;i<=n;i++)
    {
        c=a+b;
        printf(" %d",c);
        a=b;
        b=c;


    }
    return 0;
    
}

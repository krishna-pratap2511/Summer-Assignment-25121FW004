#include<stdio.h>
int main()
{
    int n,r,num,rev=0;
    printf("Enter any Number");
    scanf("%d",&n);
    num=n;
    while(n>0)
    {
        r=n%10;
        rev=rev*10+r;
        n=n/10;
    }
    if(num==rev)
    {
        printf("%d is a Palindrome Number",num);
    }
    else
    {
        printf("%d is not a Palindrome Number",num);

    }
    return 0;
}
